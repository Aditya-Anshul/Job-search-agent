# =============================================================================
# Agentic AI Job Application System — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git — it is listed in .gitignore.
# =============================================================================

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: failover | placeholder | ollama | groq | gemini | deepseek | huggingface | openai
# 'failover' allows the system to try one provider and switch to another if it fails.
LLM_PROVIDER=failover

# ── HuggingFace ──────────────────────────────────────────────────────────────
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# ── OpenAI (ChatGPT) ─────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ── Google Gemini (Free Cloud) ───────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ── DeepSeek (Free Cloud) ────────────────────────────────────────────────────
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# ── LinkedIn ─────────────────────────────────────────────────────────────────
LINKEDIN_EMAIL=your_linkedin_email@example.com
LINKEDIN_PASSWORD=your_linkedin_password

# ── Platform Credentials ──────────────────────────────────────────────────────
NAUKRI_EMAIL=your_naukri_email@example.com
NAUKRI_PASSWORD=your_naukri_password

MONSTER_EMAIL=your_monster_email@example.com
MONSTER_PASSWORD=your_monster_password

JOINDEVOPS_EMAIL=your_joindevops_email@example.com
JOINDEVOPS_PASSWORD=your_joindevops_password

# ── Telegram Notifications ────────────────────────────────────────────────────
# See README.md -> "Telegram Bot Setup" for step-by-step instructions
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Job Search Preferences ────────────────────────────────────────────────────
JOB_ROLES=DevOps Engineer,Cloud Engineer,MLOps Engineer,Platform Engineer
JOB_LOCATIONS=India,Remote,Hybrid
EXPERIENCE_YEARS=3
JOB_FRESHNESS_DAYS=2

# ── Application Settings ──────────────────────────────────────────────────────
RUN_NOW=false
MATCH_THRESHOLD=40
MAX_APPLICATIONS_PER_RUN=30
APPLY_EASY_APPLY_ONLY=false
RUN_HOUR=9
RUN_TIMEZONE=Asia/Kolkata

# ── Resume File Paths ─────────────────────────────────────────────────────────
RESUME_PDF_PATH=resume/uploads/resume.pdf
RESUME_DOCX_PATH=resume/uploads/resume.docx

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///data/job_agent.db

# ── Anti-Detection (Browser Timing) ──────────────────────────────────────────
MIN_DELAY_SECONDS=3.0
MAX_DELAY_SECONDS=12.0
HEADLESS=true

# ── SMTP Email Notifications ──────────────────────────────────────────────────
# To receive the Excel report daily via email, fill out these fields:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_email@example.com
SMTP_PASSWORD=your_smtp_app_password
